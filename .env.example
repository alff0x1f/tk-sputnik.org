DJANGO_SECRET_KEY=replace-with-your-secret-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1,http://localhost
KOLCO24_API_URL=https://kolco24.ru/api/contributors
# Required for the sync command; replace with your Kolco24 API token.
KOLCO24_API_TOKEN=replace-with-your-kolco24-api-token

# Database (DB_HOST is overridden to "db" automatically when using docker compose)
POSTGRES_DB=sputnik
POSTGRES_USER=sputnik
POSTGRES_PASSWORD=sputnik
DB_HOST=localhost
DB_PORT=5432

# phpBB MySQL (only needed when using --profile phpbb)
MYSQL_DATABASE=phpbb
MYSQL_USER=phpbb
MYSQL_PASSWORD=replace-with-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-mysql-root-password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
